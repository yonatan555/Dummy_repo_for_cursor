{
  "name": "building-management-system",
  "version": "1.0.0",
  "description": "מערכת מקיפה לניהול ואחזקת מבנים",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "dev": "nodemon server/app.js",
    "client": "cd client && npm start",
    "server": "nodemon server/app.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "install-server": "npm install",
    "install-all": "npm run install-server && npm run install-client"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "axios": "^1.5.0",
    "cron": "^2.4.4",
    "cloudinary": "^1.40.0",
    "socket.io": "^4.7.2",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "building-management",
    "property-management",
    "maintenance",
    "payments",
    "whatsapp-integration"
  ],
  "author": "Building Management System",
  "license": "MIT"
}