# Database
MONGODB_URI=mongodb://localhost:27017/building_management

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# WhatsApp API (Facebook Graph API)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Payment Integration
BIT_API_KEY=your-bit-api-key
PAYBOX_API_KEY=your-paybox-api-key

# Bank Integration (Optional)
BANK_API_URL=your-bank-api-url
BANK_API_KEY=your-bank-api-key

# Email Service (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password